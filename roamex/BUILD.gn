    "test/edge_import_adapter_unittest.cc",
    "test/roamex_appcast_verifier_unittest.cc",
    "test/edge_import_preflight_unittest.cc",
    "test/edge_import_report_unittest.cc",
    "test/edge_indexed_db_reader_unittest.cc",
    "test/edge_local_storage_reader_unittest.cc",
    "test/edge_profile_reader_unittest.cc",
    "test/edge_secret_decryptor_unittest.mm",
    "test/roamex_edge_import_driver_unittest.cc",
    "test/roamex_features_unittest.cc",
    "test/roamex_indexed_db_import_stage_unittest.cc",
    "test/roamex_overlay_mechanism_unittest.cc",
    "test/roamex_prefs_unittest.cc",
    "test/roamex_signin_build_state_unittest.cc",
    "test/roamex_signin_inert_unittest.cc",
    "test/roamex_signin_surfaces_unittest.cc",
    "test/roamex_smoke_unittest.cc",
    "test/roamex_tab_visit_observer_unittest.cc",
    "test/shortcut_registry_unittest.cc",
    "test/tab_strip_placement_observer_unittest.cc",
    "test/tab_strip_placement_unittest.cc",
    "test/tab_strip_position_menu_unittest.cc",
    "test/tab_traversal_controller_unittest.cc",
    "test/tab_uid_service_unittest.cc",
    "test/visits_store_unittest.cc",
  ]
  data = [ "test/data/sparkle/" ]
  deps = [
    "//base",
    "//base/test:run_all_unittests",  # provides main() + base::TestSuite (inits
                                      # FeatureList, AtExitManager)
    "//base/test:test_support",
    "//components/prefs:test_support",
    "//components/signin/public/base",
    "//components/user_data_importer/common",
    "//crypto",
    "//roamex/app:appcast_verifier",
    "//roamex/browser/importer",
    "//roamex/browser/profiles",
    "//roamex/browser/signin",
    "//roamex/browser/tab_visit",
    "//roamex/browser/tabs",
    "//roamex/browser/ui/tabs",
    "//roamex/common",
    "//roamex/common:crypto_passkey",
    "//roamex/utility/importer",
    "//sql",
    "//storage/common",
    "//testing/gtest",
