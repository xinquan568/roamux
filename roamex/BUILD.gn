# The //roamex overlay root (roam-1). Additive — the browser target depends on `//roamex` (plan §12.2).
# Placed at src/roamex/ in the Chromium checkout (BOOTSTRAP.md step 3).

import("//roamex/build/buildflags.gni")
import("//testing/test.gni")

group("roamex") {
  # Net-new overlay areas are added here as their epics land (E1–E6).
  deps = [
    "//roamex/app",
    "//roamex/browser/profiles",
    "//roamex/browser/signin",
    "//roamex/browser/tab_visit",
    "//roamex/browser/tabs",
    "//roamex/browser/ui/tabs",
    "//roamex/common",
  ]
}

# All Roamex test binaries. gn_all reaches tests through this group (patch 0001), so adding a test
# target here never touches the upstream patch again.
group("roamex_tests") {
  testonly = true
  deps = [
    ":roamex_browser_unittests",
    ":roamex_browsertests",
    ":roamex_unittests",
  ]
  if (roamex_enable_sparkle) {
    deps += [ ":roamex_sparkle_tests" ]
  }
}

# roam-32: the fixed pre-signed feed driven through Sparkle's own pipeline.
# Exists only on roamex_enable_sparkle=true builds (vendored framework).
if (roamex_enable_sparkle) {
  test("roamex_sparkle_tests") {
    sources = [ "test/roamex_sparkle_feed_test.mm" ]
    data = [ "test/data/sparkle/" ]
    configs += [
      "//roamex/app:sparkle_link",
      "//roamex/app:sparkle_test_rpath",
    ]
    deps = [
      "//base",
      "//base/test:run_all_unittests",
      "//base/test:test_support",
      "//net:test_support",
      "//roamex/app:app_buildflags",
      "//testing/gtest",
    ]
    frameworks = [ "Foundation.framework" ]
  }
}

# Fast unit tests — //roamex code + small deps only (no browser layer). Keep this target light.
test("roamex_unittests") {
  sources = [
