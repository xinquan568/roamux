# Roamex build-time flags (plan §12.3).

declare_args() {
  # Asserts the distributor's Google authorization (§7.3 state 3). Compiled in — never a runtime
  # toggle. Keys alone are necessary but NOT sufficient; a distributor sets this true (typically via
  # google_keys.gni, see google_keys.gni.template) only when actually authorized. Default: false —
  # the reference build is keyless AND unauthorized.
  roamex_signin_authorized_build = false
}
