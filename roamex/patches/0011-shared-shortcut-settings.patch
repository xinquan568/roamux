+  private onRoamexRebindClick_(e: Event) {
+    const key = (e.currentTarget as HTMLElement).dataset['key']!;
+    this.roamexRecordingKey_ = key;
+    this.roamexRebindStatus_ = '';
+    this.roamexKeydownListener_ = (event: KeyboardEvent) => {
+      event.preventDefault();
+      event.stopPropagation();
+      if (event.key === 'Escape') {
+        this.roamexStopRecording_();
+        return;
+      }
+      if (['Shift', 'Control', 'Alt', 'Meta'].includes(event.key)) {
+        return;
+      }
+      const chord = {
+        cmd: event.metaKey,
+        shift: event.shiftKey,
+        ctrl: event.ctrlKey,
+        opt: event.altKey,
+        keycode: event.keyCode,
+      };
+      sendWithPromise('roamexRebindShortcut', this.roamexRecordingKey_, chord)
+          .then((result: unknown) => {
+            const error = result as string;
+            this.roamexRebindStatus_ =
+                error === '' ? '' : `Rejected (${error}) — try another chord`;
+            this.roamexStopRecording_();
+            this.roamexRefreshShortcuts_();
+          });
+    };
+    document.addEventListener('keydown', this.roamexKeydownListener_, true);
+  }
+
+  private roamexStopRecording_() {
+    if (this.roamexKeydownListener_) {
+      document.removeEventListener('keydown', this.roamexKeydownListener_,
+                                   true);
+      this.roamexKeydownListener_ = null;
+    }
+    this.roamexRecordingKey_ = '';
