 #endif
 
 #if BUILDFLAG(IS_WIN)
@@ -72,6 +79,25 @@ void DetectBuiltinWindowsProfiles(
 #endif  // BUILDFLAG(IS_WIN)
 
 #if BUILDFLAG(IS_MAC)
+// Roamex (roam-15): flag-gated detection of a macOS Chromium-Edge profile.
+// The Application-Support root comes from DIR_APP_DATA so tests can override it
+// hermetically (ScopedPathOverride). Advertises only the NON-SECRET items;
+// passwords/cookies are roam-16.
+void DetectRoamexEdgeProfiles(
+    std::vector<user_data_importer::SourceProfile>* profiles) {
+  if (!base::FeatureList::IsEnabled(roamex::features::kEdgeImport)) {
+    return;
+  }
+  base::FilePath app_data;
+  if (!base::PathService::Get(base::DIR_APP_DATA, &app_data)) {
+    return;
+  }
+  if (std::optional<user_data_importer::SourceProfile> edge =
+          roamex::DetectEdgeSourceProfile(app_data)) {
+    profiles->push_back(std::move(*edge));
+  }
+}
+
 void DetectSafariProfiles(
     std::vector<user_data_importer::SourceProfile>* profiles) {
   base::ScopedBlockingCall scoped_blocking_call(FROM_HERE,
@@ -183,6 +209,7 @@ std::vector<user_data_importer::SourceProfile> DetectSourceProfilesWorker(
     DetectSafariProfiles(&profiles);
     DetectFirefoxProfiles(locale, &profiles);
   }
+  DetectRoamexEdgeProfiles(&profiles);
 #else
   DetectFirefoxProfiles(locale, &profiles);
 #endif
