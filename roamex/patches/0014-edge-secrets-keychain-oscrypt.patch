+
+void ProfileWriter::AddCookies(
+    const std::vector<net::CanonicalCookie>& cookies,
+    base::OnceCallback<void(size_t accepted)> done) {
+  network::mojom::CookieManager* cookie_manager =
+      profile_->GetDefaultStoragePartition()
+          ->GetCookieManagerForBrowserProcess();
+  // Counts only cookies the store actually accepted (IsInclude), reported once
+  // all writes complete.
+  auto accepted = std::make_unique<size_t>(0);
+  size_t* accepted_ptr = accepted.get();
+  base::RepeatingClosure barrier = base::BarrierClosure(
+      cookies.size(),
+      base::BindOnce(
+          [](std::unique_ptr<size_t> accepted,
+             base::OnceCallback<void(size_t)> done) {
+            std::move(done).Run(*accepted);
+          },
+          std::move(accepted), std::move(done)));
+  const net::CookieOptions options = net::CookieOptions::MakeAllInclusive();
+  for (const net::CanonicalCookie& cookie : cookies) {
+    const GURL source_url = net::cookie_util::CookieDomainAndPathToURL(
+        cookie.Domain(), cookie.Path(), cookie.SecureAttribute());
+    cookie_manager->SetCanonicalCookie(
+        cookie, source_url, options,
+        base::BindOnce(
+            [](base::OnceClosure b, size_t* accepted,
+               net::CookieAccessResult result) {
+              if (result.status.IsInclude()) {
+                ++*accepted;
+              }
+              std::move(b).Run();
+            },
+            barrier, accepted_ptr));
+  }
+}
