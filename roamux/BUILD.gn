# The //roamux overlay root (roam-1). Additive — the browser target depends on `//roamux` (plan §12.2).
# Placed at src/roamux/ in the Chromium checkout (BOOTSTRAP.md step 3).

import("//roamux/build/buildflags.gni")
import("//testing/test.gni")

group("roamux") {
  # Net-new overlay areas are added here as their epics land (E1–E6).
  deps = [
    "//roamux/app",
    "//roamux/browser/profiles",
    "//roamux/browser/scheme",
    "//roamux/browser/signin",
    "//roamux/browser/tab_visit",
    "//roamux/browser/tabs",
    "//roamux/browser/ui/icons",
    "//roamux/browser/ui/tabs",
    "//roamux/browser/updates:update_state_machine",
    "//roamux/common",
  ]
}

# All Roamux test binaries. gn_all reaches tests through this group (patch 0001), so adding a test
# target here never touches the upstream patch again.
group("roamux_tests") {
  testonly = true
  deps = [
    ":roamux_browser_unittests",
    ":roamux_browsertests",
    ":roamux_unittests",
  ]
  if (roamux_enable_sparkle) {
    deps += [ ":roamux_sparkle_tests" ]
  }
}

# roam-32: the fixed pre-signed feed driven through Sparkle's own pipeline.
# Exists only on roamux_enable_sparkle=true builds (vendored framework).
if (roamux_enable_sparkle) {
  test("roamux_sparkle_tests") {
    sources = [ "test/roamux_sparkle_feed_test.mm" ]
    data = [ "test/data/sparkle/" ]
    configs += [
      "//roamux/app:sparkle_link",
      "//roamux/app:sparkle_test_rpath",
    ]
    deps = [
      "//base",
      "//base/test:run_all_unittests",
      "//base/test:test_support",
      "//net:test_support",
      "//roamux/app:app_buildflags",
      "//testing/gtest",
    ]
    frameworks = [ "Foundation.framework" ]
  }
}

