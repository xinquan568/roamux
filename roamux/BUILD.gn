# Browser-layer tests — link upstream browser code (heavy first build). The roam-3 hook proof lives
# here so the fast target stays light. Deps notes (both hit for real): //chrome/browser/prefs:impl
# alone does not link (browser_prefs.cc needs the full //chrome/browser component), and a bare
# //base test main crashes (keyed-service registrars CHECK the UI thread / TestingBrowserProcess) —
# so the target uses Chrome's canonical unit-test main, //chrome/test:test_support_unit.
test("roamux_browser_unittests") {
  sources = [
    "test/roamux_browser_prefs_hook_unittest.cc",
    "test/roamux_scheme_classifier_unittest.cc",
    "test/roamux_settings_private_prefs_unittest.cc",
    "test/settled_visit_journal_service_unittest.cc",
    "test/tab_initial_url_helper_unittest.cc",
    "test/tab_initial_url_persistence_unittest.cc",
  ]
  deps = [
    "//base",
    "//chrome/browser",
    "//chrome/test:test_support_unit",
    "//components/pref_registry",
    "//components/sync_preferences:test_support",
    "//content/test:test_support",
    "//mojo/public/cpp/bindings",
    "//roamux/browser/tab_visit",
    "//roamux/common",
    "//testing/gtest",
    "//third_party/metrics_proto",
  ]

  # roam-150: test_support links the Sparkle-backed update service when
  # roamux_enable_sparkle is on, so this executable needs the rpath to load the
  # vendored Sparkle.framework at launch (the app gets it from patch 0030;
  # sparkle_link cannot carry ldflags — see the roam-121 note in app/BUILD.gn).
  if (roamux_enable_sparkle) {
    configs += [ "//roamux/app:sparkle_test_rpath" ]

    # roam-160: the native-row VersionUpdater adapter + its suite. The adapter
    # is a roamux-owned file compiled into the upstream owner of
    # version_updater_mac.mm in production (patch 0040); here it compiles with
    # its tests against the pure seam.
    sources += [
      "browser/updates/roamux_version_updater.cc",
      "browser/updates/roamux_version_updater.h",
      "test/roamux_version_updater_unittest.cc",
    ]
    deps += [ "//chrome/browser/ui" ]
  }
}

