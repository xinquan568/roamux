 std::unique_ptr<VersionUpdater> VersionUpdater::Create(
-    content::WebContents* /* web_contents */) {
+    content::WebContents* web_contents) {
+#if BUILDFLAG(ROAMUX_ENABLE_SPARKLE)
+  // Roamux (roam-160): drive the native About row from the Sparkle service
+  // (per-profile facade over the single process-wide owner). Falls through to
+  // the stock updater when no service exists (OTR / system profiles), which
+  // keeps the row's stock behaviour rather than crashing.
+  if (web_contents) {
+    if (auto* service =
+            roamux::updates::RoamuxUpdateServiceFactory::GetForProfile(
+                Profile::FromBrowserContext(
+                    web_contents->GetBrowserContext()))) {
+      return std::make_unique<roamux::updates::RoamuxVersionUpdater>(service);
+    }
+  }
+#endif
   return base::WrapUnique(new VersionUpdaterMac());
 }
