   }
+
+  // ROAMUX(roam-179): flag-gated roamux:// display branding — link/row TEXT
+  // only; hrefs stay chrome:// because renderers cannot request roamux://
+  // (the handled-scheme block). valueExists guards iOS, whose data source
+  // never adds the boolean.
+  protected isRoamuxBranding_(): boolean {
+    return loadTimeData.valueExists('roamuxSchemeDisplay') &&
