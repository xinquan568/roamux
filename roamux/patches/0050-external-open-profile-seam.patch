-        app_controller_mac::kShowProfilePickerOnFailure);
+    // Roamux (roam-213): external opens route to the designated profile when
+    // the feature is enabled and the stored profile validates; nullopt means
+    // current behavior, bit-for-bit.
+    ProfileManager* roamux_profile_manager =
+        g_browser_process->profile_manager();
+    std::optional<base::FilePath> roamux_external_profile;
+    if (roamux_profile_manager) {
+      roamux_external_profile = roamux::ResolveExternalOpenProfile(
+          *base::CommandLine::ForCurrentProcess(),
+          g_browser_process->local_state(),
+          roamux_profile_manager->user_data_dir(),
+          [roamux_profile_manager](const base::FilePath& path) {
+            return roamux_profile_manager->GetProfileAttributesStorage()
+                       .GetProfileAttributesWithPath(path) != nullptr;
+          });
+    }
+    if (roamux_external_profile) {
+      app_controller_mac::RunInProfileSafely(
+          *roamux_external_profile,
+          base::BindOnce(&OpenUrlsInBrowserWithProfile, regular_urls),
+          app_controller_mac::kShowProfilePickerOnFailure);
+    } else {
+      app_controller_mac::RunInLastProfileSafely(
+          base::BindOnce(&OpenUrlsInBrowserWithProfile, regular_urls),
+          app_controller_mac::kShowProfilePickerOnFailure);
